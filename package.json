{
  "name": "@tacuchi/updater",
  "version": "2.1.0",
  "description": "CLI multiplataforma para actualizar gestores de paquetes del sistema",
  "type": "module",
  "bin": {
    "updater": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "build": "tsup",
    "postbuild": "node scripts/assert-shebang.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "updater",
    "package-manager",
    "brew",
    "npm",
    "pip",
    "winget",
    "apt",
    "tui"
  ],
  "author": "tacuchi",
  "license": "MIT",
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "chalk": "^5.4.1",
    "env-paths": "^4.0.0",
    "execa": "^9.6.0",
    "iconv-lite": "^0.7.2",
    "ink": "^6.8.0",
    "is-admin": "^4.0.0",
    "react": "^19.2.0",
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "ink-testing-library": "^4.0.0",
    "react-devtools-core": "^7.0.1",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
