# Normalize line endings to LF everywhere. A CRLF checkout on Windows would break
# the dist/cli.js shebang (`#!/usr/bin/env node\r`), making `npx @tacuchi/updater`
# fail with a bad-interpreter error.
* text=auto eol=lf

# Source must always be LF.
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.md text eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
